{
  "name": "ftv",
  "description": "An emote extension for Fansly which adds support for emotes from popular emote extensions.",
  "private": true,
  "version": "2.0.18",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build --mv3",
    "build:firefox": "wxt build -b firefox --mv2",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "postinstall": "wxt prepare",
    "lint": "prettier --write . --plugin 'prettier-plugin-svelte' --cache | { grep -v '(unchanged)' || true; }",
    "release": "wxt zip && wxt zip -b firefox"
  },
  "devDependencies": {
    "@internationalized/date": "^3.11.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tsconfig/svelte": "^5.0.8",
    "@wxt-dev/module-svelte": "2.0.3",
    "autoprefixer": "^10.4.27",
    "bits-ui": "0.22.0",
    "clsx": "^2.1.1",
    "cmdk-sv": "^0.0.19",
    "embla-carousel-svelte": "^8.6.0",
    "formsnap": "1.0.1",
    "lucide-svelte": "^0.525.0",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svelte": "^5.53.6",
    "svelte-check": "^4.4.4",
    "svelte-sonner": "^1.0.7",
    "sveltekit-superforms": "^2.30.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^0.3.1",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vaul-svelte": "^0.3.2",
    "vite": "^6.4.1",
    "wxt": "^0.20.18",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "overrides": {
      "@sveltejs/vite-plugin-svelte@<4.0.0": ">=4.0.0",
      "svelte@<5.0.0": ">=5.0.0"
    }
  }
}
